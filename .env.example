ARCHITECT_AI_1_NAME=Doctor_ALAN_TURING
ARCHITECT_AI_1_MODEL=gpt-5.4
ARCHITECT_AI_1_DOMAIN=formal_reasoning
ARCHITECT_AI_1_TIER=orchestrator
