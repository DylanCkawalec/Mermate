# =============================================================================
# META-COGNITION GATEWAY (optional Python sidecar)
# =============================================================================
# META_GATEWAY_URL=http://localhost:8200
# META_GATEWAY_ENABLED=true
# META_CRON_INTERVAL_MS=300000

# =============================================================================
# MERMATE AGENTS DIRECTORY (for agent behavioral specifications)
# =============================================================================
# MERMATE_AGENTS_DIR=/Users/you/Desktop/MERMATE

# =============================================================================
# RUN EXPORT (dump completed run artifacts to MERMATE directory)
# =============================================================================
# MERMATE_DUMP_DIR=/Users/you/Desktop/MERMATE/dumps
# MERMATE_DUMP_RETENTION_DAYS=30

# =============================================================================
# RUN / TRACE PERSISTENCE (data efficiency)
# =============================================================================
# Default: compact JSON for runs/*.json and runs/*.trace.json (smaller, faster).
# MERMATE_RUN_JSON_PRETTY=1
# Same for flows/*/specula/*.json (modeling-brief, validation-loop, index).
# MERMATE_SPECULA_JSON_PRETTY=1
# Pipeline phase timings → debug ingest (development only; session in Cursor debug UI)
# MERMATE_DEBUG_PIPELINE=1
# Also applies to flows/<diagram>/skill.json written by the Rust packaging stage.
