# INFERENCE_KEY_FAMILY — Master key family controlling agent API identities
# Each INFERENCE_KEY_X may have additional branches (_1, _2, etc.) for "trailing" sibling agents

# Replace with your actual API keys. Never commit real keys.
MERMATE=your_openai_api_key_here
DALLE=your_dalle_api_key_here
Doctor_ALAN_TURING=your_openai_api_key_here
Doctor_GRACE_HOPPER=your_openai_api_key_here
Doctor_NERI_OXMAN=your_openai_api_key_here
Doctor_PETER_EISENMAN=your_openai_api_key_here
Doctor_PAOLA_ANTONELLI=your_openai_api_key_here

# --- INFERENCE_KEY_1 Family: Used by main GPT, some architects (1_1, 1_2, 1_3) ---
INFERENCE_KEY_1={MERMATE}         # Primary inference key 1 (Mermate main agent)
INFERENCE_KEY_1_1={MERMATE}     # Trailing architect (Architect 3)
INFERENCE_KEY_1_2={MERMATE}     # Trailing architect (Architect 7)
INFERENCE_KEY_1_3={MERMATE}     # Trailing architect (Architect 11)

# --- INFERENCE_KEY_2 Family: Used by DALL·E, some architects (2_1, 2_2, 2_3) ---
INFERENCE_KEY_2={DALLE} # Primary inference key 2 (DALLE and related)
INFERENCE_KEY_2_1={DALLE}     # Trailing architect (Architect 4)
INFERENCE_KEY_2_2={DALLE}     # Trailing architect (Architect 8)
INFERENCE_KEY_2_3={DALLE}     # Trailing architect (Architect 12)

# --- INFERENCE_KEY_3 Family: Controls trail for Architect 1, 5, 9, 13 ---
INFERENCE_KEY_3={Doctor_ALAN_TURING}      # Architect 1 (Lead: Doctor_ALAN_TURING)
INFERENCE_KEY_3_1={Doctor_ALAN_TURING}     # Trailing architect (Architect 5)
INFERENCE_KEY_3_2={Doctor_ALAN_TURING}     # Trailing architect (Architect 9)
INFERENCE_KEY_3_3={Doctor_ALAN_TURING}     # Trailing architect (Architect 13)

# --- INFERENCE_KEY_4 Family: Controls trail for Architect 2, 6, 10, 14 ---
INFERENCE_KEY_4={Doctor_GRACE_HOPPER}      # Architect 2 (Lead: Doctor_GRACE_HOPPER)
INFERENCE_KEY_4_1={Doctor_GRACE_HOPPER}     # Trailing architect (Architect 6)
INFERENCE_KEY_4_2={Doctor_GRACE_HOPPER}     # Trailing architect (Architect 10)
INFERENCE_KEY_4_3={Doctor_GRACE_HOPPER}     # Trailing architect (Architect 14)

# --- INFERENCE_KEY_5 Family: Controls Architect 15 + trail (5_1, etc.) ---
INFERENCE_KEY_5={Doctor_NERI_OXMAN}        # Architect 15 (Doctor_NERI_OXMAN)
INFERENCE_KEY_5_1={Doctor_NERI_OXMAN}     # Trailing architect (Architect 18)

# --- INFERENCE_KEY_6 Family: Controls Architect 16 + trail (6_1, etc.) ---
INFERENCE_KEY_6={Doctor_PETER_EISENMAN}      # Architect 16 (Doctor_PETER_EISENMAN)
INFERENCE_KEY_6_1={Doctor_PETER_EISENMAN}     # Trailing architect (Architect 19)

# --- INFERENCE_KEY_7 Family: Controls Architect 17 + trail (7_1, etc.) ---
INFERENCE_KEY_7={Doctor_PAOLA_ANTONELLI}      # Architect 17 (Doctor_PAOLA_ANTONELLI)
INFERENCE_KEY_7_1={Doctor_PAOLA_ANTONELLI}     # Trailing architect (Architect 20)

# ------------------------------------------------------------------------
# Key Family Mapping Examples:
#   INFERENCE_KEY_3 => 3_1, 3_2, 3_3 (covers Architects 1, 5, 9, 13)
#   INFERENCE_KEY_4 => 4_1, 4_2, 4_3 (covers Architects 2, 6, 10, 14)
#   And so forth for trailing pairs/branches

# --- Inference timeouts (ms) ---
MERMATE_INFER_TIMEOUT=180000
MERMATE_MAX_INFER_TIMEOUT=360000
MERMATE_RENDER_TIMEOUT=660000

# --- Main App Keys ---
MERMATE_AI_API_KEY={MERMATE}
MERMATE_AI_MODEL=gpt-4o
MERMATE_AI_MAX_MODEL=gpt-4o
MERMATE_AI_MAX_ENABLED=true

DALLE_AI_API_KEY={DALLE}
DALLE_AI_MAX_ENABLED=true

# -----------------------------------------------------------------------------
# HPC-GoT Controller Profile (from GoT.tex canonical schedule)
# -----------------------------------------------------------------------------
GOT_CONTROLLER_ENABLED=true
GOT_MODE=hpc_got
GOT_MAX_DEPTH=3
GOT_MAX_BRANCH=3
GOT_STATE_BUDGET=40
GOT_PRUNE_THRESHOLD=0.85
GOT_MERGE_ENABLED=true
GOT_MERGE_TOP_K=3
GOT_LLM_STAGE_LIMIT=4
GOT_ROUTER_SCORE_MODE=canonical
GOT_SCORE_STRUCTURAL_WEIGHT=0.5
GOT_SCORE_INVARIANT_WEIGHT=0.5
GOT_DEBATE_MEMORY=last_reasoning_chain
GOT_RESULT_POLICY=enhanced_simple_idea_only
GOT_REQUIRE_SEMANTIC_COMPLETENESS=true
GOT_REQUIRE_SKILL_ALIGNMENT=true
GOT_COMPILER_FORMAT=harmony
GOT_PRIMARY_LOCAL_MODEL=gpt-oss:20b

# -----------------------------------------------------------------------------
# Professor-domain mixing policy (core 4 professors mixed together)
# -----------------------------------------------------------------------------
GOT_PROFESSOR_MIX_ENABLED=true
GOT_PROFESSOR_CORE=Doctor_ALAN_TURING,Doctor_GRACE_HOPPER,Doctor_NERI_OXMAN,Doctor_PETER_EISENMAN
GOT_PROFESSOR_ADVISOR=Doctor_PAOLA_ANTONELLI
GOT_PROFESSOR_MIX_STRATEGY=parallel_debate_then_consensus
GOT_PROFESSOR_MIX_GATE=semantic_reasoning_and_completeness

# -----------------------------------------------------------------------------
# DALLE pipeline policy (4-stage image enhancement chain, start-gated)
# Start gate must pass before any DALLE architect is called.
# -----------------------------------------------------------------------------
DALLE_START_GATE_ENABLED=true
DALLE_START_GATE_CONDITION=needs_image_generation
DALLE_CHAIN_STAGES=4
DALLE_CHAIN_WINDOW_MODE=same_image_window
DALLE_CHAIN_HANDOFF=stage_to_stage
DALLE_CHAIN_ARCHITECTS=4,8,12,20
DALLE_CHAIN_RETURN=enhanced_prompt_text_only

# -----------------------------------------------------------------------------
# Agent Architecture Ensemble (20 agents, all collaborate and debate)
# -----------------------------------------------------------------------------
ARCHITECT_AI_GLOBAL_ENABLED=true
ARCHITECT_AI_GLOBAL_MODE=debate_then_merge
ARCHITECT_AI_TOTAL=20
ARCHITECT_AI_RETURN_MODE=enhanced_simple_idea_only

