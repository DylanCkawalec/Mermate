# =============================================================================
# MERMATE / HPC-GoT — Environment Configuration
#
# Pipeline: simple idea -> enhanced md -> compiled mmd -> local render
#            -> TLA+ formal spec -> TypeScript runtime
#
# Copy this file to .env and fill in your API key.
# =============================================================================

# Replace with your actual API keys. Never commit real keys.
#
# Production topology:
# - Mermate can speak directly to OpenAI-compatible APIs
# - Or route all hosted inference through Opseeq
# - All architect personas share the same primary key

# --- Opseeq AI Agent Gateway (optional unified proxy) ---
# When set, OpenAI-compatible calls route through Opseeq.
# Docker: strict tag opseeq:v5 — rebuild after each Opseeq code change:
#   npm run opseeq:docker:build && docker rm -f opseeq 2>/dev/null; docker run -d --name opseeq -p 9090:9090 --env-file .env opseeq:v5
# Or use synthesis-trade: docker compose up --build -d (builds ../opseeq automatically)
#
# OPSEEQ_URL is the single source of truth for the Opseeq service root.
# Do NOT include /v1 — each module appends path segments as needed:
#   inference-provider.js:  OPSEEQ_URL/v1/chat/completions
#   opseeq-bridge.js:       OPSEEQ_URL/api/status (management)
#   openclaw.js:             OPSEEQ_URL/api/... (management proxy)
#
# OPENAI_BASE_URL overrides OPSEEQ_URL for inference only (must include /v1).
OPSEEQ_URL=http://localhost:9090
# OPENAI_BASE_URL=http://localhost:9090/v1

# --- Primary hosted-model keys ---
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_PROJECT_KEY_HERE
CLAUDE_API_KEY=sk-ant-YOUR_CLAUDE_KEY_HERE

# --- DALL-E / GPT Image API (icon + asset generation for compiled apps) ---
# Falls back to OPENAI_API_KEY if not set. Used by icon-generator.js
# to generate custom app icons and hero banners via gpt-image-1.
DALLE_API_KEY=sk-proj-YOUR_OPENAI_PROJECT_KEY_HERE
MERMATE_IMAGE_MODEL=gpt-image-1

# Backward-compat alias
MERMATE_AI_API_KEY=sk-proj-YOUR_OPENAI_PROJECT_KEY_HERE

# =============================================================================
# TIERED MODEL STRATEGY
#
#  gpt-5.4         Orchestrator / final synthesis. Most capable.
#  gpt-5.2         Worker. Branch reasoning, enhance, decompose, composition.
#  gpt-4.1         Structured output. Reliable JSON mode.
#  gpt-4.1-mini    Fast structured. Lower cost/latency.
#  gpt-4.1-nano    Ultra-cheap. Copilot suggestions, routing.
#  gpt-image-1     Vision. Agent internal sketchpad only.
# =============================================================================

MERMATE_ORCHESTRATOR_MODEL=gpt-5.4
MERMATE_FINAL_MODEL=gpt-5.4
MERMATE_WORKER_MODEL=gpt-5.2
MERMATE_ROUTER_MODEL=gpt-4.1-nano
MERMATE_VALIDATOR_MODEL=gpt-4.1-mini
MERMATE_SUMMARIZER_MODEL=gpt-4.1-nano
MERMATE_STRUCTURED_MODEL=gpt-4.1
MERMATE_FAST_STRUCTURED_MODEL=gpt-4.1-mini

# Agent internal visualization
MERMATE_VISION_MODEL=gpt-image-1
MERMATE_VISION_MODE=metadata_only
MERMATE_VISION_RETURN=description_and_analysis

# Backward-compat: inference-provider.js reads these
MERMATE_AI_MODEL=gpt-5.2
MERMATE_AI_MAX_MODEL=gpt-5.4
MERMATE_AI_MAX_ENABLED=true

# =============================================================================
# LOCAL / SELF-HOSTED FALLBACK (gpt-oss:20b via Ollama)
# =============================================================================
LOCAL_LLM_ENABLED=true
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=gpt-oss:20b
LOCAL_LLM_API_KEY=

MERMATE_OLLAMA_URL=http://localhost:11434
MERMATE_OLLAMA_MODEL=gpt-oss:20b

# =============================================================================
# INFERENCE TIMEOUTS (milliseconds)
# =============================================================================
MERMATE_INFER_TIMEOUT=180000
MERMATE_MAX_INFER_TIMEOUT=360000
MERMATE_RENDER_TIMEOUT=660000

# =============================================================================
# HPC-GoT CONTROLLER (GoT.tex canonical schedule)
# =============================================================================
GOT_CONTROLLER_ENABLED=true
GOT_MODE=hpc_got
GOT_MAX_DEPTH=3
GOT_MAX_BRANCH=3
GOT_STATE_BUDGET=40
GOT_PRUNE_THRESHOLD=0.85
GOT_MERGE_ENABLED=true
GOT_MERGE_TOP_K=3
GOT_LLM_STAGE_LIMIT=4
GOT_ROUTER_SCORE_MODE=canonical
GOT_SCORE_STRUCTURAL_WEIGHT=0.5
GOT_SCORE_INVARIANT_WEIGHT=0.5
GOT_DEBATE_MEMORY=last_reasoning_chain
GOT_RESULT_POLICY=enhanced_simple_idea_only
GOT_REQUIRE_SEMANTIC_COMPLETENESS=true
GOT_REQUIRE_SKILL_ALIGNMENT=true
GOT_COMPILER_FORMAT=harmony
GOT_PRIMARY_LOCAL_MODEL=gpt-oss:20b

# =============================================================================
# PROFESSOR DOMAIN MIX POLICY
# =============================================================================
GOT_PROFESSOR_MIX_ENABLED=true
GOT_PROFESSOR_CORE=Doctor_ALAN_TURING,Doctor_GRACE_HOPPER,Doctor_NERI_OXMAN,Doctor_PETER_EISENMAN
GOT_PROFESSOR_ADVISOR=Doctor_PAOLA_ANTONELLI
GOT_PROFESSOR_MIX_STRATEGY=parallel_debate_then_consensus
GOT_PROFESSOR_MIX_GATE=semantic_reasoning_and_completeness

# =============================================================================
# AGENT INTERNAL VISION POLICY
# =============================================================================
AGENT_VISION_ENABLED=true
AGENT_VISION_ELIGIBLE_DOMAINS=creative_spatial,architectural_form,design_synthesis,experiential_space
AGENT_VISION_MAX_PER_AGENT=2
AGENT_VISION_RETURN_MODE=metadata_only

# =============================================================================
# AGENT ARCHITECTURE ENSEMBLE (20 personas, single shared API key)
#
# All agents use the same OPENAI_API_KEY. No per-agent keys needed.
# Each agent has: NAME, MODEL, DOMAIN, TIER, ENABLED
# =============================================================================
ARCHITECT_AI_GLOBAL_ENABLED=true
ARCHITECT_AI_GLOBAL_MODE=debate_then_merge
ARCHITECT_AI_TOTAL=20
ARCHITECT_AI_RETURN_MODE=enhanced_simple_idea_only

