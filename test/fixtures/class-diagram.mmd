    +addLine(line) void
    +confirm() void
    +cancel() void
  }

  class OrderLine {
    +String sku
    +int quantity
    +Money unitPrice
    +lineTotal() Money
  }

  class Money {
    +BigDecimal amount
    +String currency
    +add(other) Money
    +subtract(other) Money
    +isPositive() bool
  }

  class Customer {
    +String customerId
    +String email
    +Address shippingAddress
    +Money creditLimit
    +canPlaceOrder(amount) bool
  }

  class Repository~T~ {
    <<interface>>
    +find(id) T
    +save(entity) void
    +delete(id) void
  }

  Order "1" *-- "many" OrderLine : contains
  Order --> Money : totalAmount
  OrderLine --> Money : unitPrice
